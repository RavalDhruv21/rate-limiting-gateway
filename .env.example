# ─── Application ────────────────────────────────────────
APP_NAME="rate-limited-gateway"
APP_ENV="development"
LOG_LEVEL="INFO"

# ─── JWT ────────────────────────────────────────────────
# Generate a real value with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=60

# ─── Database ───────────────────────────────────────────
# v1: SQLite (local file)
# v2: change to postgresql+asyncpg://user:pass@host:5432/dbname
# DATABASE_URL="sqlite+aiosqlite:///./gateway.db"
DATABASE_URL="postgresql+asyncpg://gateway_user:gateway_pass@localhost:5432/gateway_db"
REDIS_URL="redis://localhost:6379/0"


# ─── Upstream backend ───────────────────────────────────
# The real API this gateway sits in front of.
# For learning, we use httpbin.org which echoes requests back.
UPSTREAM_BASE_URL="https://httpbin.org"

# ─── Admin ──────────────────────────────────────────────
# Static key for admin endpoints (sent in X-Admin-Key header)
ADMIN_API_KEY="change-me-admin-key"

# ─── Rate limit defaults (requests per minute per tier) ─
RATE_LIMIT_FREE=60
RATE_LIMIT_PRO=1000
RATE_LIMIT_ENTERPRISE=10000
